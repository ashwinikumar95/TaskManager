  "info": {
    "_postman_id": "add6871a-7b74-41e0-89eb-df17f027bfb1",
    "name": "Task Manager API",
    "description": "Import this file in Postman: **File → Import** → select this JSON.\n\n1. Run **Auth → Login** and copy `token` from the response into the collection variable **token** (collection → Variables tab), or set it once after login.\n2. Optionally set **projectId** and **taskId** from list/create responses for chained requests.\n\nDefault **baseUrl**: `http://localhost:3000`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "18021075"
  },
